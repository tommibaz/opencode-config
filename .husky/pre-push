#!/bin/sh

# rg exit codes: 0 = matches found, 1 = no matches, 2+ = error
# We WANT no matches (exit 1), so finding matches (exit 0) means secrets leaked.
# All output goes to stderr to avoid corrupting the TUI.

MATCHES=$(rg --no-ignore --hidden -in --column \
  '(api.?key|secret|token|password|credential|private.?key)\s*[:=]\s*["\x27]?[A-Za-z0-9_\-/+=]{8,}' \
  --glob '!node_modules' \
  --glob '!package-lock.json' \
  --glob '!.git' \
  --glob '!.husky' \
  . 2>/dev/null)
RG_EXIT=$?

if [ "$RG_EXIT" -eq 0 ]; then
  cat >&2 <<EOF

--- Pre-push: Secret scan FAILED ---

$MATCHES

BLOCKED: Potential secrets detected!
If these are false positives, push with: git push --no-verify

EOF
  exit 1
fi

echo "Pre-push: No secrets found." >&2
