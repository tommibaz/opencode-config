{
	"$schema": "https://opencode.ai/config.json",
	"plugin": ["opencode-gemini-auth@latest", "opencode-websearch-cited@1.2.0"],
	"model": "github-copilot/claude-opus-4.6",
	"mcp": {
		"semgrep": {
			"type": "local",
			"command": ["semgrep", "mcp"]
		},
		"chrome-devtools": {
			"type": "local",
			"command": ["npx", "-y", "chrome-devtools-mcp@latest"]
		}
	},
	"provider": {
		"ollama": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "Ollama (local)",
			"options": {
				"baseURL": "http://localhost:11434/v1"
			},
			"models": {
				"minimax-m2.1:cloud": {
					"name": "minimax-m2.1 Cloud"
				}
			}
		},
		"google": {
			"options": {
				"websearch_cited": {
					"model": "gemini-2.5-flash"
				}
			},
			"models": {
				"gemini-2.5-flash": {
					"options": {
						"thinkingConfig": {
							"thinkingBudget": 8192,
							"includeThoughts": true
						}
					}
				},
				"gemini-2.5-pro": {
					"options": {
						"thinkingConfig": {
							"thinkingBudget": 8192,
							"includeThoughts": true
						}
					}
				},
				"gemini-3-flash-preview": {
					"options": {
						"thinkingConfig": {
							"thinkingLevel": "high",
							"includeThoughts": true
						}
					}
				},
				"gemini-3-pro-preview": {
					"options": {
						"thinkingConfig": {
							"thinkingLevel": "high",
							"includeThoughts": true
						}
					}
				}
			}
		}
	},
	"mode": {
		"analyze": {
			"temperature": 0.1,
			"prompt": "{file:./prompts/analysis.txt}",
			"tools": {
				"bash": false,
				"edit": false,
				"write": false,
				"patch": false,
				"todowrite": false,
				"read": true,
				"grep": true,
				"glob": true,
				"list": true,
				"todoread": true,
				"webfetch": true,
				"math_add": true,
				"math_subtract": true,
				"math_multiply": true,
				"math_divide": true,
				"websearch_cited": true,
				"semgrep_semgrep_scan": true,
				"semgrep_semgrep_scan_with_custom_rule": true,
				"semgrep_semgrep_findings": true,
				"semgrep_semgrep_scan_supply_chain": true,
				"semgrep_semgrep_rule_schema": true,
				"semgrep_get_supported_languages": true,
				"semgrep_get_abstract_syntax_tree": true,
				"chrome-devtools_take_screenshot": true,
				"chrome-devtools_take_snapshot": true,
				"chrome-devtools_navigate_page": true,
				"chrome-devtools_list_pages": true,
				"chrome-devtools_select_page": true,
				"chrome-devtools_new_page": true,
				"chrome-devtools_close_page": true,
