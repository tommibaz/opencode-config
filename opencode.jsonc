{
	"$schema": "https://opencode.ai/config.json",
	"plugin": ["opencode-gemini-auth@latest", "opencode-websearch-cited@1.2.0"],
	"model": "github-copilot/claude-opus-4.6",
	"mcp": {
		"semgrep": {
			"type": "local",
			"command": ["semgrep", "mcp"]
		}
	},
	"provider": {
		"ollama": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "Ollama (local)",
			"options": {
				"baseURL": "http://localhost:11434/v1"
			},
			"models": {
				"minimax-m2.1:cloud": {
					"name": "minimax-m2.1 Cloud"
				}
			}
		},
		"google": {
			"models": {
				"gemini-2.5-flash": {
					"options": {
						"thinkingConfig": {
							"thinkingBudget": 8192,
							"includeThoughts": true
						}
					}
				},
				"gemini-2.5-pro": {
					"options": {
						"thinkingConfig": {
							"thinkingBudget": 8192,
							"includeThoughts": true
						}
					}
				},
				"gemini-3-flash-preview": {
					"options": {
						"thinkingConfig": {
							"thinkingLevel": "high",
							"includeThoughts": true
						}
					}
				},
				"gemini-3-pro-preview": {
					"options": {
						"thinkingConfig": {
							"thinkingLevel": "high",
							"includeThoughts": true
						}
					}
				}
			}
		}
	},
	"mode": {
		"analyze": {
			"temperature": 0.1,
			"prompt": "{file:./prompts/analysis.txt}",
			"tools": {
				"bash": false,
				"edit": false,
				"write": false,
				"patch": false,
				"todowrite": false,
				"read": true,
				"grep": true,
				"glob": true,
				"list": true,
				"todoread": true,
				"webfetch": true,
				"math_add": true,
				"math_subtract": true,
				"math_multiply": true,
				"math_divide": true
			}
		},
		"build": {
			"temperature": 0.0,
			"tools": {
				"bash": true,
				"edit": true,
				"write": true,
				"patch": true,
				"todowrite": true,
				"read": true,
				"grep": true,
				"glob": true,
				"list": true,
				"todoread": true,
				"webfetch": true,
				"math_add": true,
				"math_subtract": true,
				"math_multiply": true,
				"math_divide": true
			}
		},
		"plan": {
			"temperature": 0.1,
			"tools": {
				"bash": false,
				"edit": false,
				"write": false,
				"patch": false,
				"todowrite": false,
				"read": true,
				"grep": true,
				"glob": true,
				"list": true,
				"todoread": true,
				"webfetch": true,
				"math_add": true,
				"math_subtract": true,
				"math_multiply": true,
				"math_divide": true
			}
		},
		"brainstorm": {
			"temperature": 0.7,
			"prompt": "{file:./prompts/creative.txt}",
			"tools": {
				"bash": false,
				"edit": false,
				"write": false,
				"patch": false,
				"todowrite": false,
				"read": true,
				"grep": true,
				"glob": true,
				"list": true,
				"todoread": true,
				"webfetch": true,
				"math_add": true,
				"math_subtract": true,
				"math_multiply": true,
				"math_divide": true
			}
		},
		"creative": {
			"temperature": 1.0,
			"prompt": "{file:./prompts/creative.txt}",
			"tools": {
				"bash": false,
				"edit": false,
				"write": false,
				"patch": false,
				"todowrite": false,
				"read": true,
				"grep": true,
				"glob": true,
				"list": true,
				"todoread": true,
				"webfetch": true,
				"math_add": true,
				"math_subtract": true,
				"math_multiply": true,
				"math_divide": true
			}
		},
		"wild": {
			"temperature": 2.0,
			"prompt": "{file:./prompts/creative.txt}",
			"tools": {
				"bash": false,
				"edit": false,
				"write": false,
				"patch": false,
				"todowrite": false,
				"read": true,
				"grep": true,
				"glob": true,
				"list": true,
				"todoread": true,
				"webfetch": true,
				"math_add": true,
				"math_subtract": true,
				"math_multiply": true,
				"math_divide": true
			}
		}
	}
}
